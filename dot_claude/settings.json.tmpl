{
  "permissions": {
    "allow": [
      "Bash(gog gmail settings filters:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf .:*)",
      "Bash(rm -rf ..:*)",
      "Bash(chmod 777:*)",
      "Bash(chown:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(killall:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.dev.vars)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*_key)",
      "Read(**/*_key.*)",
      "Read(**/*credential*)",
      "Read(**/*password*)",
      "Read(**/*secret*)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Write(**/.env*)",
      "Write(**/secrets/**)",
      "Write(**/.ssh/*)",
      "Write(**/authorized_keys)",
      "mcp__supabase__execute_sql"
    ]
  },
{{- if .business_use }}
