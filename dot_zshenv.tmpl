# =============================================================================
# Zsh Environment (sourced for all shells)
# =============================================================================

# XDG Base Directory
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Zsh config location (disabled - using ~/.zshrc directly for simplicity)
# export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

# Locale
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# Editor
export EDITOR=nvim
export VISUAL=nvim

# Pager
export PAGER=less
export MANPAGER="less -R"

{{- if eq .chezmoi.os "darwin" }}
# =============================================================================
# macOS specific
# =============================================================================
export HOMEBREW_PREFIX="{{ .homebrew_prefix }}"
export HOMEBREW_CELLAR="{{ .homebrew_prefix }}/Cellar"
export HOMEBREW_REPOSITORY="{{ .homebrew_prefix }}"
export PATH="{{ .homebrew_prefix }}/bin:{{ .homebrew_prefix }}/sbin:$PATH"
export MANPATH="{{ .homebrew_prefix }}/share/man:$MANPATH"
export INFOPATH="{{ .homebrew_prefix }}/share/info:$INFOPATH"
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_AUTO_UPDATE=1
{{- end }}

# =============================================================================
# Path
# =============================================================================
typeset -U path PATH

# Devbox global (rebuilds PATH from its own stack — must come before user tools)
_devbox_cache="${XDG_CACHE_HOME}/devbox/shellenv.zsh"
if [[ -f "$_devbox_cache" ]]; then
  source "$_devbox_cache"
elif command -v devbox &>/dev/null; then
  mkdir -p "${XDG_CACHE_HOME}/devbox"
  # Filter out TMUX/session-specific vars to avoid breaking tmux auto-start
  devbox global shellenv | grep -Ev '^export (TMUX|TMUX_PANE|TERM_PROGRAM|TERM_PROGRAM_VERSION)=' > "$_devbox_cache"
  source "$_devbox_cache"
fi
unset _devbox_cache

# User tool paths (after devbox to avoid being overwritten)
export BUN_INSTALL="$HOME/.bun"
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$BUN_INSTALL/bin:$HOME/.moon/bin:${PATH}:${HOME}/go/bin"

# ghq root
export GHQ_ROOT="$HOME/repos"

# gitleaks global config
export GITLEAKS_CONFIG="$XDG_CONFIG_HOME/gitleaks/config.toml"

{{- if .business_use }}
# =============================================================================
# Business Environment
# =============================================================================
export BUSINESS_USE=1
{{- end }}
